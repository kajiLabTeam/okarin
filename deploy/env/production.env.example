# production application runtime
APP_ENV=production

# production postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_production
POSTGRES_USER=okarin_production
POSTGRES_PASSWORD=change_me_production_postgres_password

# production object storage (shared)
S3_INTERNAL_ENDPOINT=http://seaweedfs:8333
S3_PUBLIC_ENDPOINT=https://storage.example.com
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-production

# production Sentry configuration (shared by kaede and nozomi)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
