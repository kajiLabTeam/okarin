# production application runtime
APP_ENV=production

# production postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_production
POSTGRES_USER=okarin_production
POSTGRES_PASSWORD=change_me_production_postgres_password

# production object storage (shared)
S3_INTERNAL_ENDPOINT=http://seaweedfs:8333
S3_PUBLIC_ENDPOINT=https://storage.example.com
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-production
S3_RECORDING_UPLOAD_URL_TTL_SECONDS=900
S3_TRAJECTORY_RAW_DOWNLOAD_URL_TTL_SECONDS=86400
S3_TRAJECTORY_RESULT_UPLOAD_URL_TTL_SECONDS=86400
NOZOMI_INTERNAL_ENDPOINT=http://nozomi:8000
KAEDE_INTERNAL_BASE_URL=http://kaede:8080
KAEDE_API_SHARED_TOKEN=change_me_production_api_shared_token

# production Sentry configuration (shared by kaede and nozomi)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

  CORS_ALLOWED_ORIGINS=https://mioのorigin
  SESSION_COOKIE_SAME_SITE=None
