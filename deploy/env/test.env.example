# test application runtime
APP_ENV=test

# test postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_test
POSTGRES_USER=okarin_test
POSTGRES_PASSWORD=change_me_test_postgres_password

# test object storage (shared)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-test

# test Sentry configuration (shared by kaede and nozomi)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
