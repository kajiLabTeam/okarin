# staging application runtime
APP_ENV=staging

# staging postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_staging
POSTGRES_USER=okarin_staging
POSTGRES_PASSWORD=change_me_staging_postgres_password

# staging object storage (shared)
S3_INTERNAL_ENDPOINT=http://seaweedfs:8333
S3_PUBLIC_ENDPOINT=https://storage-staging.example.com
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-staging
S3_RECORDING_UPLOAD_URL_TTL_SECONDS=900
S3_TRAJECTORY_RAW_DOWNLOAD_URL_TTL_SECONDS=86400
S3_TRAJECTORY_RESULT_UPLOAD_URL_TTL_SECONDS=86400
NOZOMI_INTERNAL_ENDPOINT=http://nozomi:8000
KAEDE_INTERNAL_BASE_URL=http://kaede:8080

# staging Sentry configuration (shared by kaede and nozomi)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
