# production object storage credentials for kaede
S3_ACCESS_KEY_ID=kaede-production
S3_SECRET_ACCESS_KEY=change_me_production_kaede_secret_key
CALLBACK_TOKEN_SECRET=change_me_production_callback_secret
OIDC_ENABLED=true
OIDC_GOOGLE_CLIENT_ID=change_me_production_google_client_id
OIDC_GOOGLE_CLIENT_SECRET=change_me_production_google_client_secret
