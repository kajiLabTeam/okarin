# staging object storage credentials for kaede
S3_ACCESS_KEY_ID=kaede-staging
S3_SECRET_ACCESS_KEY=change_me_staging_kaede_secret_key
NOZOMI_INTERNAL_ENDPOINT=http://nozomi:8000
KAEDE_INTERNAL_BASE_URL=http://kaede:8080
CALLBACK_TOKEN_SECRET=change_me_staging_callback_secret

# staging Sentry configuration for kaede
SENTRY_DSN=https://example.com
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
