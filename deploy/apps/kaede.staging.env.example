# staging object storage credentials for kaede
S3_ACCESS_KEY_ID=kaede-staging
S3_SECRET_ACCESS_KEY=change_me_staging_kaede_secret_key
CALLBACK_TOKEN_SECRET=change_me_staging_callback_secret
OIDC_ENABLED=true
OIDC_GOOGLE_CLIENT_ID=change_me_staging_google_client_id
OIDC_GOOGLE_CLIENT_SECRET=change_me_staging_google_client_secret
OIDC_GOOGLE_REDIRECT_URI=https://kaede-staging.example.com/api/auth/oidc/google/callback
OIDC_LOGIN_SUCCESS_REDIRECT_URL=https://okarin-staging.example.com/
OIDC_LOGIN_FAILURE_REDIRECT_URL=https://okarin-staging.example.com/login
OIDC_STATE_COOKIE_SECRET=change_me_staging_oidc_state_cookie_secret
PASSWORD_LOGIN_ENABLED=true
ORGANIZATION_CREATION_REQUESTS_ENABLED=true
