# local object storage credentials for kaede
S3_ACCESS_KEY_ID=kaede-local
S3_SECRET_ACCESS_KEY=change_me_local_kaede_secret_key
CALLBACK_TOKEN_SECRET=change_me_local_callback_secret
OIDC_ENABLED=false
OIDC_GOOGLE_CLIENT_ID=change_me_local_google_client_id
OIDC_GOOGLE_CLIENT_SECRET=change_me_local_google_client_secret
OIDC_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oidc/google/callback
OIDC_LOGIN_SUCCESS_REDIRECT_URL=http://localhost:3000/
OIDC_LOGIN_FAILURE_REDIRECT_URL=http://localhost:3000/login
OIDC_STATE_COOKIE_SECRET=change_me_local_oidc_state_cookie_secret
PASSWORD_LOGIN_ENABLED=true
ORGANIZATION_CREATION_REQUESTS_ENABLED=true
