# production application runtime
APP_ENV=production

# production postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_production
POSTGRES_USER=okarin_production
POSTGRES_PASSWORD=change_me_production_postgres_password

# production object storage (seaweedfs s3 api)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-production
S3_ACCESS_KEY_ID=change_me_production_access_key
S3_SECRET_ACCESS_KEY=change_me_production_secret_key
