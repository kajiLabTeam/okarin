# production application runtime
APP_ENV=production

# production postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_production
POSTGRES_USER=okarin_production
POSTGRES_PASSWORD=change_me_production_postgres_password

# production object storage (shared)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-production

# production object storage credentials for kaede
KAEDE_S3_ACCESS_KEY_ID=change_me_production_kaede_access_key
KAEDE_S3_SECRET_ACCESS_KEY=change_me_production_kaede_secret_key

# production object storage credentials for storage bootstrap
STORAGE_BOOTSTRAP_S3_ACCESS_KEY_ID=change_me_production_storage_bootstrap_access_key
STORAGE_BOOTSTRAP_S3_SECRET_ACCESS_KEY=change_me_production_storage_bootstrap_secret_key
