# staging application runtime
APP_ENV=staging

# staging postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin_staging
POSTGRES_USER=okarin_staging
POSTGRES_PASSWORD=change_me_staging_postgres_password

# staging object storage (shared)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-staging

# staging object storage credentials for kaede
KAEDE_S3_ACCESS_KEY_ID=change_me_staging_kaede_access_key
KAEDE_S3_SECRET_ACCESS_KEY=change_me_staging_kaede_secret_key

# staging object storage credentials for storage bootstrap
STORAGE_BOOTSTRAP_S3_ACCESS_KEY_ID=change_me_staging_storage_bootstrap_access_key
STORAGE_BOOTSTRAP_S3_SECRET_ACCESS_KEY=change_me_staging_storage_bootstrap_secret_key
