# local application runtime
APP_ENV=local

# local postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin
POSTGRES_USER=okarin
POSTGRES_PASSWORD=change_me_local_postgres_password

# local object storage (shared)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-local

# local object storage credentials for kaede
KAEDE_S3_ACCESS_KEY_ID=change_me_local_kaede_access_key
KAEDE_S3_SECRET_ACCESS_KEY=change_me_local_kaede_secret_key

# local object storage credentials for storage bootstrap
STORAGE_BOOTSTRAP_S3_ACCESS_KEY_ID=change_me_local_storage_bootstrap_access_key
STORAGE_BOOTSTRAP_S3_SECRET_ACCESS_KEY=change_me_local_storage_bootstrap_secret_key
