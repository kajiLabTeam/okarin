# local application runtime
APP_ENV=local

# local postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=okarin
POSTGRES_USER=okarin
POSTGRES_PASSWORD=change_me_local_postgres_password

# local object storage (seaweedfs s3 api)
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=ap-northeast-1
S3_BUCKET=okarin-local
S3_ACCESS_KEY_ID=change_me_local_access_key
S3_SECRET_ACCESS_KEY=change_me_local_secret_key
