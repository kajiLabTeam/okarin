# production application runtime
APP_ENV=production

# use managed db in production
POSTGRES_HOST=replace-with-production-db-host
POSTGRES_PORT=5432
POSTGRES_DB=replace-with-production-db
POSTGRES_USER=replace-with-production-user
POSTGRES_PASSWORD=replace-with-production-password

# use managed object storage in production
S3_ENDPOINT=https://s3.ap-northeast-1.amazonaws.com
S3_REGION=ap-northeast-1
S3_BUCKET=replace-with-production-bucket
S3_ACCESS_KEY_ID=replace-with-production-access-key
S3_SECRET_ACCESS_KEY=replace-with-production-secret-key
